@model ProductionSystem.Models.Product
@{
    ViewData["Title"] = "Редактировать продукт";
    var materials = ViewBag.Materials as List<ProductionSystem.Models.Material> ?? new();
}

<div class="breadcrumb">
    <a href="/Products">Продукты</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Редактировать: @Model.Name</span>
</div>

<div style="max-width:780px;">
    <div class="card">
        <div class="card-header">
            <div class="card-title">Редактировать продукт</div>
        </div>
        <div class="card-body">
            <form method="post" action="/Products/Edit/@Model.Id" id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="form-grid">
                    <div class="form-group full">
                        <label class="form-label">Название *</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Категория</label>
                        <input asp-for="Category" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Время производства (мин/шт)</label>
                        <input asp-for="ProductionTimePerUnit" class="form-control" type="number" min="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Минимальный запас (шт)</label>
                        <input asp-for="MinimalStock" class="form-control" type="number" min="0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Характеристики (JSON)</label>
                        <input asp-for="Specifications" class="form-control" />
                    </div>
                </div>

                <div style="margin-top:22px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                        <div class="card-title">
                            Необходимые материалы
                            <span style="color:var(--danger);font-size:12px;font-weight:400;margin-left:8px">* минимум один материал</span>
                        </div>
                        <button type="button" class="btn btn-outline btn-sm" onclick="addMatRow()">+ Добавить</button>
                    </div>
                    <div id="matRows">
                        @* Существующие материалы рендерятся на сервере через Razor *@
                        @foreach (var pm in Model.ProductMaterials)
                        {
                            <div class="mat-row-editor" data-existing="true">
                                <select name="materialIds" class="form-control" style="flex:2">
                                    @foreach (var m in materials)
                                    {
                                        if (m.Id == pm.MaterialId)
                                        {
                                            <option value="@m.Id" selected="selected">@m.Name (@m.UnitOfMeasure)</option>
                                        }
                                        else
                                        {
                                            <option value="@m.Id">@m.Name (@m.UnitOfMeasure)</option>
                                        }
                                    }
                                </select>
                                <input name="quantities" type="number" class="form-control" style="flex:1"
                                       step="0.001" min="0.001" value="@pm.QuantityNeeded.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       placeholder="Кол-во на 1 шт" />
                                <button type="button" class="btn-remove-mat" onclick="this.closest('.mat-row-editor').remove()">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"/>
                                        <line x1="6" y1="6" x2="18" y2="18"/>
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                    <div id="matError" style="display:none;color:var(--danger);font-size:13px;margin-top:6px;">
                        ⚠ Добавьте хотя бы один материал
                    </div>
                </div>

                <div style="display:flex;gap:10px;margin-top:22px;">
                    <button type="button" class="btn btn-primary btn-lg" onclick="submitForm()">Сохранить</button>
                    <a href="/Products" class="btn btn-outline btn-lg">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// lowercase ключи — критично для работы JS
const materials = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    materials.Select(m => new {
        id            = m.Id,
        name          = m.Name,
        unitOfMeasure = m.UnitOfMeasure
    })
));

function buildOptions(selectedId) {
    return materials.map(m =>
        `<option value="${m.id}" ${m.id == selectedId ? 'selected' : ''}>${m.name} (${m.unitOfMeasure})</option>`
    ).join('');
}

function addMatRow(matId = '', qty = 1) {
    const container = document.getElementById('matRows');
    const div = document.createElement('div');
    div.className = 'mat-row-editor';
    div.innerHTML = `
        <select name="materialIds" class="form-control" style="flex:2">
            <option value="">— выберите материал —</option>
            ${buildOptions(matId)}
        </select>
        <input name="quantities" type="number" class="form-control" style="flex:1"
               step="0.001" min="0.001" value="${qty}" placeholder="Кол-во на 1 шт" />
        <button type="button" class="btn-remove-mat" onclick="this.closest('.mat-row-editor').remove()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>`;
    container.appendChild(div);
    document.getElementById('matError').style.display = 'none';
}

function submitForm() {
    const rows = document.querySelectorAll('#matRows .mat-row-editor');
    const filled = Array.from(rows).filter(r => {
        const sel = r.querySelector('select[name="materialIds"]');
        return sel && sel.value !== '';
    });
    if (filled.length === 0) {
        document.getElementById('matError').style.display = 'block';
        document.getElementById('matRows').scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
    }
    document.getElementById('editForm').submit();
}
</script>
}

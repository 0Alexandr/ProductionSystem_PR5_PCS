@model IEnumerable<ProductionSystem.Models.WorkOrder>
@{
    ViewData["Title"] = "Производственные заказы";
    string? statusFilter = ViewBag.StatusFilter;
    string? dateFilter = ViewBag.DateFilter;
}

<div class="page-header">
    <div>
        <h1>Производственные заказы</h1>
        <p>Планирование и контроль выполнения</p>
    </div>
    <a href="/Orders/Create" class="btn btn-accent btn-lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Создать заказ
    </a>
</div>

<div class="filters">
    @{
        var statuses = new[] {
            ("", "Все"),
            ("Pending", "Ожидает"),
            ("InProgress", "В работе"),
            ("Completed", "Завершён"),
            ("Cancelled", "Отменён")
        };
    }
    @foreach (var (val, label) in statuses)
    {
        var isActive = statusFilter == val || (string.IsNullOrEmpty(val) && string.IsNullOrEmpty(statusFilter));
        <a href="/Orders?status=@val"
           class="btn @(isActive ? "btn-primary" : "btn-outline") btn-sm">@label</a>
    }
    <a href="/Orders?date=today&status=@statusFilter"
       class="btn @(dateFilter == "today" ? "btn-info" : "btn-outline") btn-sm">📅 Сегодня</a>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">Заказы <span class="badge badge-secondary" style="margin-left:8px">@Model.Count()</span></div>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>№</th>
                    <th>Продукт</th>
                    <th>Кол-во</th>
                    <th>Линия</th>
                    <th>Статус</th>
                    <th>Прогресс</th>
                    <th>Начало</th>
                    <th>Завершение</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td>@order.Product?.Name</td>
                        <td>@order.Quantity шт</td>
                        <td style="font-size:12.5px">@(order.ProductionLine?.Name ?? "—")</td>
                        <td>@Html.Partial("_StatusBadge", order.Status)</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;min-width:120px">
                                <div class="progress-bar-wrap" style="flex:1">
                                    <!-- Добавляем ID и data-order-id. Также добавляем класс js-order-progress для скрипта -->
                                    <div id="bar-fill-@order.Id"
                                         class="progress-bar-fill js-order-progress @(order.Progress > 60 ? "green" : order.Progress > 30 ? "orange" : "blue")"
                                         data-order-id="@order.Id"
                                         data-status="@order.Status"
                                         style="width:@order.Progress%">
                                    </div>
                                </div>
                                <span id="bar-text-@order.Id" style="font-size:12px;color:var(--text-muted);white-space:nowrap">
                                    @order.Progress%
                                </span>
                            </div>
                        </td>
                        <td style="font-size:12.5px;white-space:nowrap">@order.StartDate.ToString("dd.MM.yy HH:mm")</td>
                        <td style="font-size:12.5px;white-space:nowrap;@(order.EstimatedEndDate < DateTime.Now && order.Status != "Completed" && order.Status != "Cancelled" ? "color:var(--danger);font-weight:700" : "")">
                            @order.EstimatedEndDate.ToString("dd.MM.yy HH:mm")
                        </td>
                        <td>
                            <div style="display:flex;gap:5px;flex-wrap:wrap;">
                                <a href="/Orders/Details/@order.Id" class="btn btn-outline btn-sm">👁 Подробнее</a>
                                @if (order.Status == "Pending")
                                {
                                    <form method="post" action="/Orders/Launch/@order.Id" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm">▶ Запустить</button>
                                    </form>
                                }
                                @if (order.Status == "InProgress")
                                {
                                    <form method="post" action="/Orders/Complete/@order.Id" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-info btn-sm">✓ Завершить</button>
                                    </form>
                                }
                                @if (order.Status == "Pending" || order.Status == "InProgress")
                                {
                                    <form method="post" action="/Orders/Cancel/@order.Id" style="display:inline"
                                          onsubmit="return confirm('Отменить заказ #@order.Id?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">✕ Отменить</button>
                                    </form>
                                }
                                @if (order.Status == "Completed" || order.Status == "Cancelled")
                                {
                                    <form method="post" action="/Orders/Delete/@order.Id" style="display:inline"
                                          onsubmit="return confirm('Удалить заказ #@order.Id навсегда?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm"
                                                style="border:1px solid var(--danger); color:var(--danger); background:transparent">
                                            🗑 Удалить
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9"><div class="empty-state"><p>Заказов не найдено</p></div></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        async function refreshOrders() {
            // Находим все полоски прогресса заказов, которые сейчас "В работе"
            const activeBars = document.querySelectorAll('.progress-bar-fill[data-status="InProgress"]');

            for (let bar of activeBars) {
                // Берем ID заказа из атрибута (который мы добавили в прошлом шаге)
                const orderId = bar.getAttribute('data-order-id');

                try {
                    // Вызываем ваш API, который сам все считает в базе
                    const response = await fetch(`/api/orders/${orderId}/progress/auto`);
                    if (!response.ok) continue;

                    const data = await response.json();

                    // Обновляем ширину полоски
                    bar.style.width = data.progress + '%';

                    // Обновляем текст процентов (ищем соседний span)
                    const textSpan = document.getElementById(`bar-text-${orderId}`);
                    if (textSpan) textSpan.innerText = data.progress + '%';

                    // Меняем цвет как в Details
                    bar.classList.remove('green', 'orange', 'blue');
                    const colorClass = data.progress > 60 ? 'green' : (data.progress > 30 ? 'orange' : 'blue');
                    bar.classList.add(colorClass);

                    // Если заказ завершился, можно либо перезагрузить, либо просто закрасить в зеленый
                    if (data.status === 'Completed') {
                        bar.style.width = '100%';
                        if (textSpan) textSpan.innerText = '100%';
                    }
                } catch (e) {
                    console.warn('Ошибка обновления заказа ' + orderId, e);
                }
            }
        }

        // Запускаем обновление каждые 5 секунд (как в вашем Details)
        setInterval(refreshOrders, 5000);
    </script>
}
@model IEnumerable<ProductionSystem.Models.Material>
@{
    ViewData["Title"] = "Материалы";
    bool lowStock = ViewBag.LowStock == true;
}

<div class="page-header">
    <div>
        <h1>Управление материалами</h1>
        <p>Контроль остатков и пополнение склада</p>
    </div>
    <a href="/Materials/Create" class="btn btn-primary btn-lg">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Добавить материал
    </a>
</div>

<div class="filters">
    <a href="/Materials" class="btn @(!lowStock ? "btn-primary" : "btn-outline") btn-sm">Все</a>
    <a href="/Materials?lowStock=true" class="btn @(lowStock ? "btn-danger" : "btn-outline") btn-sm">
        ⚠ Низкий запас
    </a>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">
            Список материалов
            <span class="badge badge-secondary" style="margin-left:8px">@Model.Count() позиций</span>
        </div>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Количество</th>
                    <th>Ед. изм.</th>
                    <th>Мин. запас</th>
                    <th>Статус</th>
                    <th>Пополнить</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td><strong>@m.Name</strong></td>
                        <td>
                            <div class="qty-cell">
                                <div class="qty-indicator @(m.IsLowStock ? "qty-low" : "qty-ok")"></div>
                                <span style="@(m.IsLowStock ? "color:var(--danger);font-weight:700" : "")">
                                    @m.Quantity
                                </span>
                            </div>
                        </td>
                        <td>@m.UnitOfMeasure</td>
                        <td>@m.MinimalStock</td>
                        <td>
                            @if (m.IsLowStock)
                            {
                                <span class="badge badge-danger">⚠ Низкий запас</span>
                            }
                            else
                            {
                                <span class="badge badge-success">✓ Достаточно</span>
                            }
                        </td>
                        <td>
                            <form method="post" action="/Materials/Replenish/@m.Id" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="number" name="amount" class="form-control" 
                                       step="0.001" min="0.001" placeholder="Кол-во" value="@(m.MinimalStock - m.Quantity > 0 ? (m.MinimalStock - m.Quantity) : 10)" />
                                <button type="submit" class="btn btn-success btn-sm">+ Пополнить</button>
                            </form>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a href="/Materials/Edit/@m.Id" class="btn btn-outline btn-sm">✎ Изменить</a>
                                <form method="post" action="/Materials/Delete/@m.Id" style="display:inline"
                                      onsubmit="return confirm('Удалить материал «@m.Name»?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">✕</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8"/></svg>
                                <p>Материалов не найдено</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

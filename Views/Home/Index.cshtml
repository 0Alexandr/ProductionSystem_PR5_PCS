@model IEnumerable<ProductionSystem.Models.WorkOrder>
@{
    ViewData["Title"] = "Панель управления";
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.TotalOrders</div>
            <div class="stat-label">Всего заказов</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.ActiveOrders</div>
            <div class="stat-label">В производстве</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.PendingOrders</div>
            <div class="stat-label">Ожидают запуска</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.LowStockCount</div>
            <div class="stat-label">Низкий запас</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.ActiveLines</div>
            <div class="stat-label">Активных линий</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon teal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 1 1 4.93 19.07"/></svg>
        </div>
        <div class="stat-body">
            <div class="stat-value">@ViewBag.TotalProducts</div>
            <div class="stat-label">Продуктов</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">Последние заказы</div>
        <a href="/Orders" class="btn btn-outline btn-sm">Все заказы →</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>№</th>
                    <th>Продукт</th>
                    <th>Кол-во</th>
                    <th>Линия</th>
                    <th>Статус</th>
                    <th>Прогресс</th>
                    <th>Срок завершения</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td>@order.Product?.Name</td>
                        <td>@order.Quantity шт</td>
                        <td>@(order.ProductionLine?.Name ?? "—")</td>
                        <td>@Html.Partial("_StatusBadge", order.Status)</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div class="progress-bar-wrap" style="width:80px">
                                    <div class="progress-bar-fill @(order.Progress > 60 ? "green" : order.Progress > 30 ? "orange" : "blue")"
                                         style="width:@order.Progress%"></div>
                                </div>
                                <span style="font-size:12px;color:var(--text-muted)">@order.Progress%</span>
                            </div>
                        </td>
                        <td style="font-size:12.5px;color:var(--text-muted)">
                            @order.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7"><div class="empty-state"><p>Заказов пока нет</p></div></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

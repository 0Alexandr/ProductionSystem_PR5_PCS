@model ProductionSystem.Models.ProductionLine
@{
    ViewData["Title"] = "Новая линия";
}

<div class="breadcrumb">
    <a href="/Lines">Линии</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Добавить линию</span>
</div>

<div style="max-width:520px">
    <div class="card">
        <div class="card-header"><div class="card-title">Новая производственная линия</div></div>
        <div class="card-body">
            <form method="post" action="/Lines/Create">
                @Html.AntiForgeryToken()
                <div class="form-grid single">
                    <div class="form-group">
                        <label class="form-label">Название линии *</label>
                        <input asp-for="Name" class="form-control" placeholder="Например: Линия А — Сборка" />
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Начальный статус</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Active">Активна</option>
                            <option value="Stopped">Остановлена</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Коэффициент эффективности (0.5 – 2.0)</label>
                        <input asp-for="EfficiencyFactor" class="form-control" type="number"
                               step="0.1" min="0.5" max="2.0" id="effInput" />
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px">
                            1.0 — нормальная скорость, &gt;1.0 — быстрее, &lt;1.0 — медленнее
                        </div>
                    </div>
                </div>
                <div style="display:flex;gap:10px;margin-top:22px;">
                    <button type="submit" class="btn btn-primary btn-lg">Создать линию</button>
                    <a href="/Lines" class="btn btn-outline btn-lg">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>
